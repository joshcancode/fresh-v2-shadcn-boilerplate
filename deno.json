{
  "nodeModulesDir": "auto",
  "tasks": {
    "check": "deno fmt --check . && deno lint . && deno check",
    "dev": "vite",
    "build": "vite build",
    "start": "deno serve -A _fresh/server.js",
    "update": "deno run -A -r jsr:@fresh/update ."
  },
  "lint": {
    "rules": {
      "tags": [
        "fresh",
        "recommended"
      ]
    }
  },
  "exclude": [
    "**/_fresh/*"
  ],
  "imports": {
    "@/": "./",
    "@shadcn/react": "npm:@shadcn/react@^0.2.1",
    "fresh": "jsr:@fresh/core@^2.3.3",
    "preact": "npm:preact@^10.29.7",
    "@preact/signals": "npm:@preact/signals@^2.9.3",
    "@fresh/plugin-vite": "jsr:@fresh/plugin-vite@^1.1.2",
    "react-qr-code": "npm:react-qr-code@^2.2.0",
    "vite": "npm:vite@^7.3.6",
    "@types/babel__core": "npm:@types/babel__core@^7.20.5",
    "tailwindcss": "npm:tailwindcss@^4.1.10",
    "@tailwindcss/vite": "npm:@tailwindcss/vite@^4.3.2",
    "@base-ui/react": "npm:@base-ui/react@^1.6.0",
    "@tanstack/react-table": "npm:@tanstack/react-table@^8.21.3",
    "class-variance-authority": "npm:class-variance-authority@^0.7.1",
    "clsx": "npm:clsx@^2.1.1",
    "cmdk": "npm:cmdk@^1.1.1",
    "date-fns": "npm:date-fns@^4.4.0",
    "embla-carousel-react": "npm:embla-carousel-react@^8.6.0",
    "input-otp": "npm:input-otp@^1.4.2",
    "lucide-preact": "npm:lucide-preact@^1.23.0",
    "react-day-picker": "npm:react-day-picker@^10.0.1",
    "react-resizable-panels": "npm:react-resizable-panels@^4.12.1",
    "recharts": "npm:recharts@^3.9.2",
    "sonner": "npm:sonner@^2.0.7",
    "tailwind-merge": "npm:tailwind-merge@^3.6.0",
    "tw-animate-css": "npm:tw-animate-css@^1.4.0",
    "vaul": "npm:vaul@^1.1.2"
  },
  "compilerOptions": {
    "lib": [
      "dom",
      "dom.asynciterable",
      "dom.iterable",
      "deno.ns"
    ],
    "jsx": "precompile",
    "jsxImportSource": "preact",
    "jsxPrecompileSkipElements": [
      "a",
      "img",
      "source",
      "body",
      "html",
      "head",
      "title",
      "meta",
      "script",
      "link",
      "style",
      "base",
      "noscript",
      "template"
    ],
    "types": [
      "vite/client"
    ]
  }
}